<Window x:Class="TempMaster.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TempMaster.App"
        xmlns:controls="clr-namespace:TempMaster.App.Controls"
        xmlns:vm="clr-namespace:TempMaster.App.ViewModels"
        mc:Ignorable="d"
        Title="Temp Master 監視盤"
        Height="760" Width="1180"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <DataTemplate x:Key="MeterCardTemplate" DataType="{x:Type vm:MeterViewModel}">
            <Border Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="8"
                    Width="350"
                    Padding="14">
                <StackPanel>
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="{Binding DisplayName}" FontSize="16" FontWeight="Bold" TextTrimming="CharacterEllipsis" />
                            <TextBlock Style="{StaticResource MutedText}">
                                <Run Text="{Binding RawName, Mode=OneWay}" />
                                <Run Text=" / " />
                                <Run Text="{Binding DeviceType, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                        <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                Background="{Binding SeverityBrush}"
                                CornerRadius="10" Padding="10,3">
                            <TextBlock Text="{Binding SeverityLabel}" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                        </Border>
                    </Grid>

                    <Grid Margin="0,12,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="温度" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding TemperatureText}" FontSize="24" FontWeight="Bold"
                                       Foreground="{Binding SeverityBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="湿度" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding HumidityText}" FontSize="24" FontWeight="Bold" Foreground="#3DB8E9" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="バッテリー" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding BatteryText}" FontSize="24" FontWeight="Bold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                        <Setter Property="Foreground" Value="#2ECC71" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BatteryLow}" Value="True">
                                                <Setter Property="Foreground" Value="#E74C3C" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>

                    <Border CornerRadius="6" ClipToBounds="True" Height="140">
                        <controls:LineChart Readings="{Binding History}" />
                    </Border>

                    <TextBlock Text="{Binding LastUpdatedText}" Style="{StaticResource MutedText}" Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <StackPanel>
                <TextBlock Text="Temp Master 監視盤" FontSize="24" FontWeight="Bold" />
                <TextBlock Text="ケミカルプラント 温度監視システム" Style="{StaticResource MutedText}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Ellipse Width="12" Height="12" Fill="{Binding StatusBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock Text="{Binding ConnectionStatus}" VerticalAlignment="Center" FontWeight="SemiBold" />
            </StackPanel>
        </Grid>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,12">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="バックエンド URL" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBox Width="320" Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" />
                    <TextBlock Text="更新間隔(秒)" VerticalAlignment="Center" Margin="14,0,6,0" />
                    <TextBox Width="60" Text="{Binding RefreshSeconds, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" />
                    <Button Content="適用" Command="{Binding ApplySettingsCommand}" Margin="8,0,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="期間" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox Width="140" ItemsSource="{Binding TimeScales}" SelectedItem="{Binding SelectedTimeScale}"
                              VerticalAlignment="Center">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource TimeScaleLabel}}" Foreground="#111111" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Content="再読込" Command="{Binding ReloadCommand}" Margin="10,0,0,0"
                            Background="#34495E" />
                    <Button Content="今すぐ収集" Command="{Binding RefreshNowCommand}" Margin="8,0,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Meter grid -->
        <Grid Grid.Row="2">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Meters}" ItemTemplate="{StaticResource MeterCardTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>

            <Border Background="#0F141A" Opacity="0.6"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="読み込み中..." HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="18" FontWeight="SemiBold" />
            </Border>

            <TextBlock Text="メーターがありません。バックエンド URL と認証情報をご確認ください。"
                       HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Meters.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <!-- Footer -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <TextBlock Text="{Binding LastUpdatedText}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
            <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                       Text="{Binding ErrorText}" Foreground="#E74C3C" TextTrimming="CharacterEllipsis" MaxWidth="600" />
        </Grid>
    </Grid>
</Window>
