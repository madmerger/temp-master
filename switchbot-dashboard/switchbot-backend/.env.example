# SwitchBot API Credentials
# Get these from the SwitchBot app:
# 1. Go to Profile > Preferences > About
# 2. Tap App Version 10 times to enable Developer Options
# 3. Go to Developer Options > Get Token

SWITCHBOT_TOKEN=your_token_here
SWITCHBOT_SECRET=your_secret_here

# CORS allowed origins (comma-separated)
# Default: https://temp-master.fly.dev
# Development: http://localhost:5173,http://localhost:8000
ALLOWED_ORIGINS=https://temp-master.fly.dev

# Admin API key for /api/backup and /api/import endpoints
# Generate a strong random key, e.g.: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=
