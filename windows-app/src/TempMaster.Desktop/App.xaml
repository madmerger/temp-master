<Application x:Class="TempMaster.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Status badge colors mirror the web dashboard's Bootstrap labels. -->
        <SolidColorBrush x:Key="TempBrush" Color="#D9534F" />
        <SolidColorBrush x:Key="HumidityBrush" Color="#5BC0DE" />
        <SolidColorBrush x:Key="BatteryBrush" Color="#5CB85C" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#5CB85C" />
        <SolidColorBrush x:Key="DangerBrush" Color="#D9534F" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#DDDDDD" />
        <SolidColorBrush x:Key="CardHeaderBrush" Color="#F8F8F8" />
        <SolidColorBrush x:Key="MutedBrush" Color="#777777" />

        <!-- Small pill-style badge used for the live readings. -->
        <Style x:Key="BadgeText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Application.Resources>
</Application>
