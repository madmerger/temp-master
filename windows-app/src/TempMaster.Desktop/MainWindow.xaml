<Window x:Class="TempMaster.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Temp Master Dashboard"
        Width="1180"
        Height="820"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        FontFamily="Segoe UI">
    <DockPanel>
        <!-- Menu bar (native Windows look) -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem x:Name="MenuRefresh" Header="_Refresh Data" InputGestureText="F5" Click="OnRefreshClick" />
                <MenuItem x:Name="MenuBackup" Header="Download _Backup" Click="OnBackupClick" />
                <Separator />
                <MenuItem Header="E_xit" Click="OnExitClick" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About Temp Master" Click="OnAboutClick" />
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <ToolBarTray DockPanel.Dock="Top" IsLocked="True">
            <ToolBar Band="0" BandIndex="0">
                <TextBlock Text="Time Range:" VerticalAlignment="Center" Margin="4,0,6,0" />
                <ComboBox x:Name="TimeScaleCombo"
                          Width="150"
                          SelectionChanged="OnTimeScaleChanged">
                    <ComboBoxItem Tag="hour">Last Hour</ComboBoxItem>
                    <ComboBoxItem Tag="day" IsSelected="True">Last 24 Hours</ComboBoxItem>
                    <ComboBoxItem Tag="week">Last 7 Days</ComboBoxItem>
                    <ComboBoxItem Tag="month">Last 30 Days</ComboBoxItem>
                    <ComboBoxItem Tag="year">Last Year</ComboBoxItem>
                </ComboBox>
                <Separator />
                <Button x:Name="RefreshButton" Click="OnRefreshClick" Padding="10,3">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x21bb;" FontSize="14" Margin="0,0,5,0" />
                        <TextBlock Text="Refresh Data" />
                    </StackPanel>
                </Button>
                <Button x:Name="BackupButton" Click="OnBackupClick" Padding="10,3" Margin="4,0,0,0">
                    <TextBlock Text="Download Backup" />
                </Button>
            </ToolBar>
        </ToolBarTray>

        <!-- Status bar (bottom, native) -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="FooterText"
                           Text="Temp Master Dashboard v1.0 - Windows Native (WPF)" />
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="SourceText" Foreground="#777777" />
            </StatusBarItem>
        </StatusBar>

        <!-- Header band with title + connection status -->
        <Border DockPanel.Dock="Top" Background="White" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
            <Grid Margin="16,10">
                <TextBlock Text="Temp Master Dashboard"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="MetersCountText"
                               Foreground="#777777"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0" />
                    <Border x:Name="StatusBadge"
                            Background="{StaticResource SuccessBrush}"
                            CornerRadius="3"
                            Padding="10,4">
                        <TextBlock x:Name="StatusText"
                                   Text="Connecting..."
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   FontSize="13" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Rate limit / error banner -->
        <Border x:Name="BannerBorder"
                DockPanel.Dock="Top"
                Background="#FCF8E3"
                BorderBrush="#FAEBCC"
                BorderThickness="0,0,0,1"
                Padding="16,10"
                Visibility="Collapsed">
            <TextBlock x:Name="BannerText" Foreground="#8A6D3B" TextWrapping="Wrap" />
        </Border>

        <!-- Main content -->
        <Grid>
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                <ItemsControl x:Name="MetersItems">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>

            <TextBlock x:Name="LoadingText"
                       Text="Loading temperature data..."
                       Foreground="#777777"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Grid>
    </DockPanel>
</Window>
