<Window x:Class="TempMasterDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        xmlns:vm="clr-namespace:TempMasterDesktop.ViewModels"
        Title="Temp Master Desktop"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="600"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🌡️" FontSize="22" Margin="0,0,10,0" VerticalAlignment="Center" />
                    <TextBlock Text="Temp Master Desktop" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="v1.0" FontSize="12" Margin="10,4,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border x:Name="StatusBadge" CornerRadius="10" Padding="10,4" Margin="0,0,10,0"
                            Background="{StaticResource SuccessBrush}">
                        <TextBlock x:Name="StatusText" Text="Connected" FontSize="11"
                                   Foreground="White" FontWeight="SemiBold" />
                    </Border>
                    <TextBlock x:Name="MetersCountText" Text="0 meters"
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Controls Bar -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" Padding="16,8"
                BorderBrush="#3F3F5F" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Time Range:" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0" />
                <ComboBox x:Name="TimeScaleCombo" Width="160" Style="{StaticResource DarkComboBox}"
                          SelectionChanged="TimeScaleCombo_SelectionChanged" />
                <Button x:Name="RefreshButton" Content="🔄 Refresh Data"
                        Style="{StaticResource AccentButton}" Margin="16,0,0,0"
                        Click="RefreshButton_Click" />
                <TextBlock x:Name="LastRefreshText" Text=""
                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="16,0,0,0" />
            </StackPanel>
        </Border>

        <!-- Rate Limit Warning -->
        <Border x:Name="RateLimitBanner" Grid.Row="2" VerticalAlignment="Top"
                Background="#44F59E0B" Padding="12,8" Margin="16,8,16,0"
                CornerRadius="6" Visibility="Collapsed">
            <TextBlock Text="⚠️ SwitchBot API rate limit reached. Data may be stale."
                       Foreground="{StaticResource WarningBrush}" FontSize="12" />
        </Border>

        <!-- Meters Grid -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
            <ItemsControl x:Name="MetersPanel">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Margin="8,0" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource CardBrush}" CornerRadius="10"
                                Margin="8" Padding="16" Width="380"
                                BorderBrush="#3F3F5F" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="200" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <StackPanel Grid.Row="0" Margin="0,0,0,8">
                                    <TextBlock Text="{Binding DisplayName}" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding DeviceType}" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" />
                                </StackPanel>

                                <!-- Stats -->
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                                    <Border Background="#44EF4444" CornerRadius="4" Padding="8,4" Margin="0,0,6,0">
                                        <TextBlock Text="{Binding TemperatureText}" FontSize="14" FontWeight="Bold"
                                                   Foreground="{StaticResource DangerBrush}" />
                                    </Border>
                                    <Border Background="#4406B6D4" CornerRadius="4" Padding="8,4" Margin="0,0,6,0">
                                        <TextBlock Text="{Binding HumidityText}" FontSize="14" FontWeight="Bold"
                                                   Foreground="{StaticResource InfoBrush}" />
                                    </Border>
                                    <Border Background="#4410B981" CornerRadius="4" Padding="8,4">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🔋" FontSize="12" Margin="0,0,4,0" />
                                            <TextBlock Text="{Binding BatteryText}" FontSize="14" FontWeight="Bold"
                                                       Foreground="{StaticResource SuccessBrush}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Chart -->
                                <oxy:PlotView Grid.Row="2" x:Name="ChartView"
                                              Background="Transparent"
                                              Tag="{Binding DeviceId}" Loaded="PlotView_Loaded" />

                                <!-- Last Updated -->
                                <TextBlock Grid.Row="3" Text="{Binding LastUpdatedText}"
                                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,8,0,0" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}" Padding="16,8">
            <TextBlock Text="Temp Master Desktop v1.0 — WPF / .NET 8"
                       FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" />
        </Border>
    </Grid>
</Window>
